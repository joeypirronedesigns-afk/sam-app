{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.samforcreators.com"
        }
      ],
      "destination": "https://samforcreators.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/welcome",
      "destination": "/welcome.html"
    },
    {
      "source": "/meet",
      "destination": "/meet.html"
    },
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/",
      "destination": "/meet.html"
    }
  ],
  "functions": {
    "api/pdf.js": {
      "memory": 3009,
      "maxDuration": 60
    },
    "api/sam.js": {
      "maxDuration": 60
    },
    "api/waitlist.js": {
      "maxDuration": 10
    },
    "api/stripe-checkout.js": {
      "maxDuration": 10
    },
    "api/stripe-webhook.js": {
      "maxDuration": 10
    },
    "api/auth.js": {
      "maxDuration": 10
    }
  }
}